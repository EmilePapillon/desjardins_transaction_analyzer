# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments (present locally)
.venv/
venv/
env/
bin/
lib/
lib64/
include/
share/
pyvenv.cfg

# Editor cruft
.idea/
.vscode/
.DS_Store

# PyInstaller / build artifacts
dist/
build/
*.spec

# Generated artifacts
html/
*.html
*.csv
.extracts_ignore.yaml
.extracts_ignore.yml
.extracts_ignore.json

# Large inputs / statement PDFs (may contain personal data — never commit)
releves/**/*.pdf
releves_bkp/**/*.pdf
tests/support/*.pdf

# UI screenshots (may show account details)
resources/*.png

# Editor swap files
*.swp
*.swo
